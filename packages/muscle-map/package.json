{
  "name": "@fitgram/muscle-map",
  "version": "0.1.1",
  "description": "Muscle heatmap for React Native — turns a workout's exercises into a colour-coded body map.",
  "main": "./lib/commonjs/index.js",
  "module": "./lib/module/index.js",
  "types": "./lib/typescript/commonjs/index.d.ts",
  "react-native": "./src/index.tsx",
  "source": "./src/index.tsx",
  "exports": {
    ".": {
      "import": {
        "types": "./lib/typescript/module/index.d.ts",
        "default": "./lib/module/index.js"
      },
      "require": {
        "types": "./lib/typescript/commonjs/index.d.ts",
        "default": "./lib/commonjs/index.js"
      }
    }
  },
  "files": [
    "src",
    "lib",
    "README.md"
  ],
  "scripts": {
    "build": "bob build",
    "prepare": "bob build",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "react-native",
    "muscle",
    "heatmap",
    "body",
    "workout",
    "fitness"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "react-native-body-highlighter": ">=3.0.0",
    "react-native-svg": "*"
  },
  "devDependencies": {
    "react-native-builder-bob": "^0.42.1"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "commonjs",
        {
          "esm": true
        }
      ],
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}
